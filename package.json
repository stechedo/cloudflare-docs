{
	"name": "cloudflare-docs-starlight",
	"private": true,
	"type": "module",
	"scripts": {
		"preinstall": "pnpx only-allow pnpm",
		"astro": "astro",
		"prebuild": "tsx bin/fetch-skills.ts",
		"build": "export NODE_OPTIONS='--max-old-space-size=8192' || set NODE_OPTIONS=\"--max-old-space-size=8192\" && astro build",
		"typegen:worker": "wrangler types ./worker/worker-configuration.d.ts",
		"check": "pnpm run check:astro && pnpm run check:worker",
		"check:astro": "astro check",
		"check:worker": "tsc --noEmit -p ./worker/tsconfig.json",
		"predev": "tsx bin/fetch-skills.ts --soft",
		"dev": "astro dev",
		"format": "pnpm run format:core:fix && pnpm run format:data",
		"format:core": "prettier \"**/*.{js,jsx,ts,tsx,mjs,css}\"",
		"format:core:check": "prettier --check \"**/*.{js,jsx,ts,tsx,mjs,css}\"",
		"format:core:fix": "prettier --write \"**/*.{js,jsx,ts,tsx,mjs,css}\"",
		"format:content": "prettier --write \"**/*.{md,mdx,astro}\"",
		"format:data": "prettier --write \"**/*.{json,yaml,yml}\"",
		"postinstall": "patch-package",
		"preview": "astro preview",
		"script:optimize-svgs": "tsx scripts/optimize-svgs.ts",
		"start": "astro dev",
		"sync": "astro sync",
		"test": "vitest",
		"test:prebuild": "vitest --project Node --project Astro",
		"test:postbuild": "vitest --project Workers",
		"flue:dev": "flue dev --env .env.local",
		"flue:build": "flue build",
		"flue:deploy": "pnpm run flue:build && pnpm run flue:sync-skills:remote && wrangler deploy --config .flue/dist/wrangler.jsonc --secrets-file .flue/.env",
		"flue:sync-skills": "pnpm run flue:sync-skills:remote",
		"flue:sync-skills:local": "wrangler r2 object put docs-flue-bucket/.agents/skills/spam-and-off-topic-filter/SKILL.md --file .flue/.agents/skills/spam-and-off-topic-filter/SKILL.md --local --persist-to .flue/dist/.wrangler/state",
		"flue:sync-skills:remote": "wrangler r2 object put docs-flue-bucket/.agents/skills/spam-and-off-topic-filter/SKILL.md --file .flue/.agents/skills/spam-and-off-topic-filter/SKILL.md --remote",
		"lint": "eslint",
		"ai-setup:import-from-opencode": "rulesync import --targets opencode --features rules,commands,subagents",
		"ai-setup:claudecode": "pnpm run ai-setup:import-from-opencode && rulesync generate --targets claudecode --features rules,commands,subagents",
		"ai-setup:cursor": "pnpm run ai-setup:import-from-opencode && rulesync generate --targets cursor --features commands,subagents",
		"ai-setup:copilot": "pnpm run ai-setup:import-from-opencode && rulesync generate --targets copilot --features commands,subagents",
		"prepare": "husky"
	},
	"devDependencies": {
		"@actions/core": "3.0.1",
		"@actions/github": "9.1.1",
		"@apidevtools/swagger-parser": "12.1.0",
		"@astrojs/check": "0.9.9",
		"@astrojs/mdx": "5.0.4",
		"@astrojs/react": "5.0.4",
		"@astrojs/rss": "4.0.18",
		"@astrojs/sitemap": "3.7.2",
		"@astrojs/starlight": "0.39.2",
		"@astrojs/starlight-docsearch": "0.7.0",
		"@astrojs/starlight-tailwind": "5.0.0",
		"@base-ui/react": "1.4.1",
		"@cloudflare/vitest-pool-workers": "0.16.4",
		"@cloudflare/workers-types": "4.20260511.1",
		"@eslint/js": "9.39.4",
		"@expressive-code/core": "0.42.0",
