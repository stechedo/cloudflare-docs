		"@floating-ui/react": "0.27.19",
		"@flue/cli": "0.7.0",
		"@flue/runtime": "0.7.0",
		"@iarna/toml": "2.2.5",
		"@iconify/utils": "3.1.3",
		"@marsidev/react-turnstile": "1.5.2",
		"@nanostores/react": "1.1.0",
		"@octokit/auth-app": "8.2.0",
